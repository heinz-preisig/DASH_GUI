@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix css: <http://digipass.com/css#> .

@prefix ex: <http://example.org/ex/> .

ex:DropdownIriExample a sh:NodeShape ;
    sh:targetClass ex:CountryRef ;
    sh:property [
        sh:path ex:country ;
        rdfs:label "Country" ;
        sh:nodeKind sh:IRI ;
        sh:in (
            country:DE
            country:FR
            country:NO
            country:US
            country:GB
        ) ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] .
