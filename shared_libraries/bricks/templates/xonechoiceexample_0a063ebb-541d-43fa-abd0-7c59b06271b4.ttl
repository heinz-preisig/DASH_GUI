@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix css: <http://digipass.com/css#> .

@prefix ex: <http://example.org/ex/> .

ex:XoneChoiceExample a sh:NodeShape ;
    sh:targetClass ex:ContactMethod ;
    sh:xone (
        [
            sh:property [
                sh:path ex:email ;
                rdfs:label "Email" ;
                sh:datatype xsd:string ;
                sh:minCount 1 ;
                sh:maxCount 1 ;
            ] ;
        ]
        [
            sh:property [
                sh:path ex:phone ;
                rdfs:label "Phone" ;
                sh:datatype xsd:string ;
                sh:minCount 1 ;
                sh:maxCount 1 ;
            ] ;
        ]
        [
            sh:property [
                sh:path ex:postal ;
                rdfs:label "Postal Address" ;
                sh:datatype xsd:string ;
                sh:minCount 1 ;
                sh:maxCount 1 ;
            ] ;
        ]
    ) .
