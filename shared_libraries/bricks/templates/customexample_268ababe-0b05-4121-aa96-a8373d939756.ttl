@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix css: <http://digipass.com/css#> .

@prefix ex: <http://example.org/ex/> .

ex:CustomExample a sh:NodeShape ;
    sh:targetClass ex:CustomThing ;
    sh:property [
        sh:path ex:name ;
        rdfs:label "Name" ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        dash:singleLine "true" ;
    ] ;
    sh:property [
        sh:path ex:score ;
        rdfs:label "Score" ;
        sh:datatype xsd:decimal ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minInclusive 0.0 ;
        sh:maxInclusive 100.0 ;
    ] ;
    sh:property [
        sh:path ex:status ;
        rdfs:label "Status" ;
        sh:nodeKind sh:IRI ;
        sh:in (
            ex:Active
            ex:Inactive
            ex:Pending
        ) ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path ex:createdOn ;
        rdfs:label "Created" ;
        sh:datatype xsd:date ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] .
