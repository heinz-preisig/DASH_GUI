@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix css: <http://digipass.com/css#> .

@prefix ex: <http://example.org/ex/> .

ex:StaticLabelExample a sh:NodeShape ;
    sh:targetClass ex:FixedRecord ;
    sh:property [
        sh:path ex:schemaVersion ;
        rdfs:label "Schema Version" ;
        sh:hasValue ""1.0"" ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] ;
    sh:property [
        sh:path ex:dataOwner ;
        rdfs:label "Data Owner" ;
        sh:hasValue "ex:AcmeCorp" ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
    ] .
