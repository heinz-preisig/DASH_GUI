@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .

<http://example.org/organization_nodeshape> a sh:NodeShape ;
    rdfs:label "Organization NodeShape" ;
    rdfs:comment "Basic organization shape" ;
    sh:nodeKind "IRI" ;
    sh:targetClass <foaf:Organization> .

