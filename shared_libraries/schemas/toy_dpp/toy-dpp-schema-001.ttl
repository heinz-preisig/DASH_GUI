@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dash: <http://datashapes.org/dash#> .
@prefix dpp: <https://ec.europa.eu/dpp/toy#> .
@prefix schema: <https://schema.org/> .

dpp:ToyDigitalProductPassport a sh:NodeShape ;
    sh:targetClass https://schema.org/Product ;
    sh:property [
        sh:path https://schema.org/productID ;
        rdfs:label "Unique Product Identifier" ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path https://schema.org/name ;
        rdfs:label "Toy Model Name" ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path https://schema.org/description ;
        rdfs:label "Toy Model Description" ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path https://schema.org/image ;
        rdfs:label "Product Image URL" ;
        sh:datatype xsd:anyURI ;
    ] ;
    sh:property [
        sh:path https://schema.org/identifier ;
        rdfs:label "Commodity Code" ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path https://schema.org/description ;
        rdfs:label "Manufacturer Responsibility Statement" ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path https://schema.org/legislationIdentifier ;
        rdfs:label "Union Law Reference" ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path https://schema.org/identifier ;
        rdfs:label "Harmonised Standard Reference" ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path https://schema.org/description ;
        rdfs:label "Declaration of Conformity Replacement" ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path https://schema.org/additionalProperty ;
        rdfs:label "CE Marking Present" ;
        sh:datatype xsd:boolean ;
    ] ;
    sh:property [
        sh:path https://schema.org/additionalProperty ;
        rdfs:label "Allergenic Fragrance" ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path https://schema.org/url ;
        rdfs:label "Distributor Communication Channel" ;
        sh:datatype xsd:anyURI ;
    ] ;
    sh:property [
        sh:path https://schema.org/url ;
        rdfs:label "DPP Service Provider Reference" ;
        sh:datatype xsd:anyURI ;
    ] ;
    sh:property [
        sh:path https://schema.org/url ;
        rdfs:label "Safety Gate Portal Link" ;
        sh:datatype xsd:anyURI ;
    ] ;
    sh:property [
        sh:path https://schema.org/description ;
        rdfs:label "Safety Information and Warnings" ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path https://schema.org/description ;
        rdfs:label "Instructions of Use" ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path schema:manufacturer ;
        sh:node dpp:EconomicOperator ;
        rdfs:label "Manufacturer" ;
        sh:description "Manufacturer. Annex VI Part I (b)." ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:order 0 ;
    ] ;
    sh:property [
        sh:path schema:accountablePerson ;
        sh:node dpp:EconomicOperator ;
        rdfs:label "Responsible Operator" ;
        sh:description "Responsible operator (Article 11 / Annex VI Part I (c)). Only required if different from manufacturer." ;
        sh:minCount 0 ;
        sh:maxCount 1 ;
        sh:order 1 ;
    ] ;
    sh:property [
        sh:path schema:certification ;
        sh:node dpp:NotifiedBody ;
        rdfs:label "Notified Body" ;
        sh:description "Notified body that intervened in conformity assessment. Annex VI Part I (j)." ;
        sh:minCount 0 ;
        sh:order 2 ;
    ] .

dpp:EconomicOperator a sh:NodeShape ;
    sh:targetClass https://schema.org/Organization ;
    sh:property [
        sh:path https://schema.org/legalName ;
        rdfs:label "Legal Name" ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path https://schema.org/streetAddress ;
        rdfs:label "Street Address" ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path https://schema.org/addressLocality ;
        rdfs:label "City / Locality" ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path https://schema.org/postalCode ;
        rdfs:label "Postal Code" ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path https://schema.org/addressCountry ;
        rdfs:label "Country" ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path https://schema.org/identifier ;
        rdfs:label "Unique Operator Identifier" ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path https://schema.org/email ;
        rdfs:label "Email" ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path https://schema.org/url ;
        rdfs:label "Website URL" ;
        sh:datatype xsd:anyURI ;
    ] .

dpp:NotifiedBody a sh:NodeShape ;
    sh:targetClass https://schema.org/Organization ;
    sh:property [
        sh:path https://schema.org/name ;
        rdfs:label "Name" ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path https://schema.org/identifier ;
        rdfs:label "Notified Body Number" ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path https://schema.org/identifier ;
        rdfs:label "Certificate Reference" ;
        sh:datatype xsd:string ;
    ] ;
    sh:property [
        sh:path https://schema.org/url ;
        rdfs:label "Certificate URL" ;
        sh:datatype xsd:anyURI ;
    ] .

