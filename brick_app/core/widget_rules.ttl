# ── Predicate-based rules (fallback 1: query cached ontology graphs) ──────────

dashgui:QudtApplicableUnitRule a dashgui:WidgetRule ;
    dashgui:widget "unit_dropdown" ;
    dashgui:label "QUDT Quantity" ;
    dashgui:triggerPredicate <http://qudt.org/schema/qudt/applicableUnit> .

dashgui:QudtQuantityKindRule a dashgui:WidgetRule ;
    dashgui:widget "unit_dropdown" ;
    dashgui:label "QUDT Quantity Kind" ;
    dashgui:triggerPredicate <http://qudt.org/schema/qudt/hasQuantityKind> .

dashgui:SkosConceptSchemeRule a dashgui:WidgetRule ;
    dashgui:widget "skos_selector" ;
    dashgui:label "SKOS Concept" ;
    dashgui:triggerPredicate <http://www.w3.org/2004/02/skos/core#inScheme> .

dashgui:SkosMemberRule a dashgui:WidgetRule ;
    dashgui:widget "skos_selector" ;
    dashgui:label "SKOS Collection" ;
    dashgui:triggerPredicate <http://www.w3.org/2004/02/skos/core#member> .


# ── Namespace-based rules (fallback 2: IRI prefix match) ─────────────────────

dashgui:FoafPersonRule a dashgui:WidgetRule ;
    dashgui:widget "property_suggestions" ;
    dashgui:label "FOAF Agent" ;
    dashgui:triggerNamespace "http://xmlns.com/foaf/0.1/" ;
    dashgui:triggerSubClassOf <http://xmlns.com/foaf/0.1/Agent> .

dashgui:SchemaOrgRule a dashgui:WidgetRule ;
    dashgui:widget "property_suggestions" ;
    dashgui:label "Schema.org Class" ;
    dashgui:triggerNamespace "https://schema.org/" .
